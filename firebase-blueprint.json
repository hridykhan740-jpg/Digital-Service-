{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including balance and contact details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "mobile", "balance", "role"]
    },
    "Submission": {
      "title": "Service Submission",
      "description": "User submissions for various services.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["facebook_verification", "website_dev", "app_dev", "sim_offer"] },
        "details": { "type": "object" },
        "paymentScreenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "status", "createdAt"]
    },
    "SimOffer": {
      "title": "SIM Offer",
      "description": "Mobile operator offers.",
      "type": "object",
      "properties": {
        "operator": { "type": "string", "enum": ["GP", "Robi", "Banglalink", "Airtel", "Robi/Airtel Family"] },
        "type": { "type": "string", "enum": ["Bundle", "Minute", "Internet"] },
        "title": { "type": "string" },
        "price": { "type": "string" },
        "validity": { "type": "string" },
        "description": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["operator", "type", "title", "price", "validity", "active"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "User",
      "description": "User accounts"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Collection of user service requests"
    },
    "sim_offers/{offerId}": {
      "schema": "SimOffer",
      "description": "Collection of available SIM offers"
    }
  }
}
