{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with balance and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "$ref": "#/entities/Role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "balance", "role"]
    },
    "Service": {
      "title": "Platform Service",
      "description": "Configuration for available services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "active": { "type": "boolean" },
        "adminOnly": { "type": "boolean" },
        "priceInfo": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "active"]
    },
    "Submission": {
      "title": "Submissions/Orders",
      "description": "Requests from users for various services",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "serviceType": { "type": "string" },
        "details": { "type": "object" },
        "paymentScreenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "status", "createdAt"]
    },
    "SimOffer": {
      "title": "SIM Offer",
      "description": "Available mobile offers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "operator": { "type": "string" },
        "type": { "type": "string", "enum": ["Bundle", "Minute", "Internet"] },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "validity": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "operator", "type", "title", "price", "active"]
    },
    "Note": {
      "title": "User Note",
      "description": "Individual notes for user tally/tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    },
    "Role": {
      "title": "User Role",
      "description": "Role definitions with permissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "permissions"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "services/{serviceId}": {
      "schema": "Service",
      "description": "Service definitions"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "User requests for services"
    },
    "sim_offers/{offerId}": {
      "schema": "SimOffer",
      "description": "Available SIM offers"
    },
    "notes/{noteId}": {
      "schema": "Note",
      "description": "Private user notes"
    },
    "roles/{roleId}": {
      "schema": "Role",
      "description": "Role definitions"
    }
  }
}
