{
  "entities": {
    "PlatformService": {
      "title": "Platform Service",
      "description": "A service offered by the platform (e.g. Facebook Verification)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "active": { "type": "boolean" },
        "priceInfo": { "type": "string" },
        "adminOnly": { "type": "boolean" }
      },
      "required": ["id", "title", "active"]
    },
    "SimOffer": {
      "title": "SIM Offer",
      "description": "A mobile package offer",
      "type": "object",
      "properties": {
        "operator": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "string" },
        "validity": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["operator", "title", "price", "validity"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Submission": {
      "title": "Submission",
      "description": "A service request or order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "rejected"] },
        "details": { "type": "object" },
        "paymentScreenshot": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notification/log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/services": {
      "schema": "PlatformService",
      "description": "Available platform services"
    },
    "/sim_offers": {
      "schema": "SimOffer",
      "description": "Available SIM packages"
    },
    "/users": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/submissions": {
      "schema": "Submission",
      "description": "Order submissions"
    },
    "/notifications": {
      "schema": "Notification",
      "description": "Activity logs and notifications"
    }
  }
}
