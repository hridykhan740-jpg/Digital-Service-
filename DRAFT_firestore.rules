rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // We check the 'role' field in the users collection
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.mobile is string && data.mobile.size() <= 20 &&
             data.balance is number && data.balance >= 0 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidSubmission(data) {
      return data.userId == request.auth.uid &&
             data.serviceType is string &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      // Prevent self-elevation on create:
                      incoming().role == 'user' && 
                      incoming().balance == 0;
      
      allow update: if (isAdmin() && isValidUser(incoming())) || 
                      (isOwner(userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'mobile']) &&
                       incoming().name is string && incoming().name.size() > 0 &&
                       incoming().mobile is string && incoming().mobile.size() <= 20);
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sim_offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidSubmission(incoming()) &&
                      // Ensure the user document exists before submitting
                      exists(/databases/$(database)/documents/users/$(request.auth.uid));
      
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasAny(['status']) &&
                      incoming().status in ['pending', 'completed', 'rejected'];
      
      allow delete: if isAdmin();
    }
    
    // Explicitly allow admins based on hardcoded emails to bootstrap
    // This part is risky but often necessary for initial setup
    match /users/{userId} {
      allow write: if isSignedIn() && (request.auth.token.email == 'mhossenali740@gmail.com' || request.auth.token.email == 'hridykhan740@gmail.com') && request.auth.token.email_verified == true;
    }
  }
}
