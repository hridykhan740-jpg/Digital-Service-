rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'mhossenali740@gmail.com' ||
              request.auth.token.email == 'hridykhan740@gmail.com' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.mobile is string && data.mobile.size() <= 20 &&
             data.balance is number && data.balance >= 0 &&
             data.role is string && data.role.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidRole(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.permissions is list && data.permissions.size() <= 100;
    }

    function isValidSubmission(data) {
      return data.userId == request.auth.uid &&
             data.serviceType is string && data.serviceType.size() <= 50 &&
             data.status == 'pending' &&
             data.createdAt == request.time &&
             data.details is map && data.details.size() <= 50;
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'user' && 
                      incoming().balance == 0;
      
      allow update: if (isAdmin() && isValidUser(incoming())) || 
                      (isOwner(userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'mobile']) &&
                       incoming().name is string && incoming().name.size() > 0 &&
                       incoming().mobile is string && incoming().mobile.size() <= 20);
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sim_offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidSubmission(incoming()) &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid));
      
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['pending', 'completed', 'rejected', 'success'];
      
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().title is string && incoming().title.size() <= 200 &&
                      incoming().content is string && incoming().content.size() <= 10000 &&
                      incoming().createdAt == request.time;
      
      allow read, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn() && 
                      existing().userId == request.auth.uid &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']) &&
                      incoming().title is string && incoming().title.size() <= 200 &&
                      incoming().content is string && incoming().content.size() <= 10000 &&
                      incoming().updatedAt == request.time;
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
