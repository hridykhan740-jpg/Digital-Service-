rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['mhossenali740@gmail.com', 'hridykhan740@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    match /users/{userId} {
      // Allow users to read their own profile or admins to read all
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Allow creation of profile if it's the current user
      allow create: if isOwner(userId);
      
      // Allow updates to own profile (limited) or admin full access
      allow update: if isOwner(userId) || isAdmin();
    }

    match /services/{serviceId} {
      // Allow anyone to see services (needed for homepage)
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sim_offers/{offerId} {
      // Allow anyone to see offers
      allow read: if true;
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      // Allow users to see their own submissions or admins to see all
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Allow creation if the user is authenticated and the data matches their UID
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow admins to update status, or users to delete their own pending
      allow update, delete: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending');
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read, write: if isAdmin();
    }
    
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Services connection test document
    match /services/connection-test {
      allow read: if true;
    }
  }
}
